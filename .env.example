# --- Waitlist (always-on) ---
# Supabase is the production sink. Set these to persist signups across deploys.
# Get them from your Supabase project → Settings → API.
# IMPORTANT: SUPABASE_SERVICE_ROLE_KEY is a server-only secret — never expose it client-side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: pipe every waitlist signup to a Slack / Discord / Zapier webhook.
WAITLIST_WEBHOOK_URL=

# --- Product features (currently dormant — code exists at /train, /generate) ---
# Add these when you're ready to flip on the full voice-trained generator.
ANTHROPIC_API_KEY=

# Optional: auto-post to X. OAuth 2.0 user token with tweet.write + users.read.
X_BEARER_TOKEN=

# Optional: auto-post to Meta Threads. Long-lived user access token.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
